ub â one /ws endpoint, fan-out by client `role`.\\n\\nTwo kinds of clients share this hub:\\n\\n* **Viewers** (e.g. `role=panel`): anonymous, read-only. The server `broadcast()`s events to\\n  every socket of the role; inbound messages are ignored. The kitchen panel uses this to get\\n  new orders/tasks âĶ","sessionId":"4323b4d6-f974-46db-8593-fd95f56001f7","subtitle":"{\"file_path\":\"/home/ducduy/AI_Waiver/src/backend/app/ws.py\"}","timestamp":"2026-06-25T18:06:23.765Z","title":"Read","type":"file_read"},"obs_mqttd5g9_ce1df240b0d8":{"concepts":[],"confidence":0.3,"facts":[],"files":["/home/ducduy/AI_Waiver/src/backend/app/dispatcher.py"],"id":"obs_mqttd5g9_ce1df240b0d8","importance":5,"narrative":"{\"file_path\":\"/home/ducduy/AI_Waiver/src/backend/app/dispatcher.py\"} | {\"type\":\"text\",\"file\":{\"filePath\":\"/home/ducduy/AI_Waiver/src/backend/app/dispatcher.py\",\"content\":\"\\\"\\\"\\\"Dispatcher â turns business events into robot tasks and assigns them to robots.\\n\\nThis is the \\\"shift manager\\\": it never moves anything itself. When a business event happens\\n(a party is seated, the kitchen marks an ordeâĶ","sessionId":"4323b4d6-f974-46db-8593-fd95f56001f7","subtitle":"{\"file_path\":\"/home/ducduy/AI_Waiver/src/backend/app/dispatcher.py\"}","timestamp":"2026-06-25T18:06:32.332Z","title":"Read","type":"file_read"},"obs_mqttf23n_2e9a619217f0":{"concepts":[],"confidence":0.3,"facts":[],"files":["/home/ducduy/AI_Waiver/src/backend/app/fleet.py"],"id":"obs_mqttf23n_2e9a619217f0","importance":5,"narrative":"{\"content\":\"\\\"\\\"\\\"In-memory live robot telemetry (pose + battery).\\n\\nHigh-frequency, latest-value-only, ephemeral â kept in RAM, NOT the orchestrator DB. A robot\\nstreams heartbeats several times a second while driving; persisting each one would hammer the\\nsingle SQLite file and contend with order/payment writes (a write takes a file-level lock).\\nLosing a tick is harmless: the next heartbeat (âĶ","sessionId":"4323b4d6-f974-46db-8593-fd95f56001f7","subtitle":"{\"content\":\"\\\"\\\"\\\"In-memory live robot telemetry (pose + battery).\\n\\nHigh-frequency, latest-value-only, ephemeral â keâĶ","timestamp":"2026-06-25T18:08:01.301Z","title":"Write","type":"file_write"},"obs_mqttfj4p_006b506c88de":{"concepts":[],"confidence":0.3,"facts":[],"files":["/home/ducduy/AI_Waiver/src/backend/app/dispatcher.py"],"id":"obs_mqttfj4p_006b506c88de","importance":5,"narrative":"{\"file_path\":\"/home/ducduy/AI_Waiver/src/backend/app/dispatcher.py\",\"new_string\":\"from . import fleet\\nfrom .config import settings\\nfrom .db import get_conn\\nfrom .schemas import RobotOut, TaskOut\\nfrom .ws import manager\",\"old_string\":\"from .config import settings\\nfrom .db import get_conn\\nfrom .schemas import RobotOut, TaskOut\\nfrom .ws import manager\",\"replace_all\":false} | {\"filePath\":\"/homâĶ","sessionId":"4323b4d6-f974-46db-8593-fd95f56001f7","subtitle":"{\"file_path\":\"/home/ducduy/AI_Waiver/src/backend/app/dispatcher.py\",\"new_string\":\"from . import fleet\\nfrom .config impâĶ","timestamp":"2026-06-25T18:08:23.372Z","title":"Edit","type":"file_edit"},"obs_mqttfrby_eef302c9f924":{"concepts":[],"confidence":0.3,"facts":[],"files":["/home/ducduy/AI_Waiver/src/backend/app/dispatcher.py"],"id":"obs_mqttfrby_eef302c9f924","importance":5,"narrative":"{\"file_path\":\"/home/ducduy/AI_Waiver/src/backend/app/dispatcher.py\",\"new_string\":\"# Last time (monotonic) we pushed a robot's live pose to the panel. Heartbeats can arrive several\\n# times a second while a robot is moving; we throttle the minimap broadcast so a big fleet can't\\n# flood the panel socket. Live pose/battery live in RAM (fleet.py), NOT the DB â see on_heartbeat.\\n_last_pose_bcast: diâĶ","sessionId":"4323b4d6-f974-46db-8593-fd95f56001f7","subtitle":"{\"file_path\":\"/home/ducduy/AI_Waiver/src/backend/app/dispatcher.py\",\"new_string\":\"# Last time (monotonic) we pushed a râĶ","timestamp":"2026-06-25T18:08:33.999Z","title":"Edit","type":"file_edit"},"obs_mqttg34j_70d26f65ea2a":{"concepts":[],"confidence":0.3,"facts":[],"files":["/home/ducduy/AI_Waiver/src/backend/app/dispatcher.py"],"id":"obs_mqttg34j_70d26f65ea2a","importance":5,"narrative":"{\"file_path\":\"/home/ducduy/AI_Waiver/src/backend/app/dispatcher.py\",\"new_string\":\"async def _broadcast_robot(conn, robot_id: str) -> None:\\n    # Identity/assignment come from the DB row (read in the caller's transaction so an\\n    # uncommitted status change is reflected); live pose/battery are layered from RAM.\\n    row = conn.execute(\\\"SELECT * FROM robots WHERE id = ?\\\", (robot_id,)).fetchoneâĶ","sessionId":"4323b4d6-f974-46db-8593-fd95f56001f7","subtitle":"{\"file_path\":\"/home/ducduy/AI_Waiver/src/backend/app/dispatcher.py\",\"new_string\":\"async def _broadcast_robot(conn, roboâĶ","timestamp":"2026-06-25T18:08:49.285Z","title":"Edit","type":"file_edit"},"obs_mqttgf2j_5454325fb542":{"concepts":[],"confidence":0.3,"facts":[],"files":["/home/ducduy/AI_Waiver/src/backend/app/dispatcher.py"],"id":"obs_mqttgf2j_5454325fb542","importance":5,"narrative":"{\"file_path\":\"/home/ducduy/AI_Waiver/src/backend/app/dispatcher.py\",\"new_string\":\"    online = manager.connected_robot_ids()\\n    candidates = []\\n    for r in conn.execute(\\\"SELECT * FROM robots WHERE status = 'idle'\\\").fetchall():\\n        if r[\\\"id\\\"] not in online:\\n            continue\\n        # Live pose/battery (RAM) over the DB snapshot, so \\\"nearest + charged enough\\\" uses the\\n        âĶ","sessionId":"4323b4d6-f974-46db-8593-fd95f56001f7","subtitle":"{\"file_path\":\"/home/ducduy/AI_Waiver/src/backend/app/dispatcher.py\",\"new_string\":\"    online = manager.connected_robot_âĶ","timestamp":"2026-06-25T18:09:04.765Z","title":"Edit","type":"file_edit"},"obs_mqtth26r_3d7ea58d5fb2":{"concepts":[],"confidence":0.3,"facts":[],"files":["/home/ducduy/AI_Waiver/src/backend/app/dispatcher.py"],"id":"obs_mqtth26r_3d7ea58d5fb2","importance":5,"narrative":"{\"f