921f7a":{"observation":{"concepts":[],"confidence":0.3,"facts":[],"files":["/home/ducduy/AI_Waiver/src/backend/app/ws.py"],"id":"obs_mqttcyub_943418921f7a","importance":5,"narrative":"{\"file_path\":\"/home/ducduy/AI_Waiver/src/backend/app/ws.py\"} | {\"file\":{\"content\":\"\\\"\\\"\\\"WebSocket hub ā one /ws endpoint, fan-out by client `role`.\\n\\nTwo kinds of clients share this hub:\\n\\n* **Viewers** (e.g. `role=panel`): anonymous, read-only. The server `broadcast()`s events to\\n  every socket of the role; inbound messages are ignored. The kitchen panel uses this to get\\n  new orders/tasks ā¦","sessionId":"4323b4d6-f974-46db-8593-fd95f56001f7","subtitle":"{\"file_path\":\"/home/ducduy/AI_Waiver/src/backend/app/ws.py\"}","timestamp":"2026-06-25T18:06:23.765Z","title":"Read","type":"file_read"},"sessionId":"4323b4d6-f974-46db-8593-fd95f56001f7","type":"compressed"},"obs_mqttd5g9_ce1df240b0d8":{"observation":{"concepts":[],"confidence":0.3,"facts":[],"files":["/home/ducduy/AI_Waiver/src/backend/app/dispatcher.py"],"id":"obs_mqttd5g9_ce1df240b0d8","importance":5,"narrative":"{\"file_path\":\"/home/ducduy/AI_Waiver/src/backend/app/dispatcher.py\"} | {\"type\":\"text\",\"file\":{\"filePath\":\"/home/ducduy/AI_Waiver/src/backend/app/dispatcher.py\",\"content\":\"\\\"\\\"\\\"Dispatcher ā turns business events into robot tasks and assigns them to robots.\\n\\nThis is the \\\"shift manager\\\": it never moves anything itself. When a business event happens\\n(a party is seated, the kitchen marks an ordeā¦","sessionId":"4323b4d6-f974-46db-8593-fd95f56001f7","subtitle":"{\"file_path\":\"/home/ducduy/AI_Waiver/src/backend/app/dispatcher.py\"}","timestamp":"2026-06-25T18:06:32.332Z","title":"Read","type":"file_read"},"sessionId":"4323b4d6-f974-46db-8593-fd95f56001f7","type":"compressed"},"obs_mqttf23n_2e9a619217f0":{"observation":{"concepts":[],"confidence":0.3,"facts":[],"files":["/home/ducduy/AI_Waiver/src/backend/app/fleet.py"],"id":"obs_mqttf23n_2e9a619217f0","imp