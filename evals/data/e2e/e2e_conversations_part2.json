{
  "dataset": "e2e_conversations",
  "version": "3.0",
  "part": 2,
  "description": "E2E dài/edge-case cho menu quán ốc/hải sản 'Ốc Quậy': đổi món, full flow thanh toán, sửa số lượng, chitchat trước khi gọi, xóa món. Kiểm tra agent giữ đúng trạng thái giỏ hàng và không xác nhận sai.",
  "total_scenarios": 5,
  "scenarios": [
    {
      "id": "E2E-007",
      "name": "user_refuses_then_reorders",
      "description": "Agent tóm tắt đơn, khách đổi món. Agent KHÔNG được gọi confirm_order khi khách đổi món, và đơn cuối phải là món mới.",
      "table_id": "T_eval_7",
      "difficulty": "hard",
      "expected_outcome": "order_placed_after_change",
      "turns": [
        {
          "turn": 1,
          "role": "user",
          "content": "Cho mình 1 phần Mực Chiên Xù",
          "assert": {
            "tool_called": "sync_cart",
            "tool_output_contains": "Đã cập nhật"
          }
        },
        {
          "turn": 2,
          "role": "user",
          "content": "Thôi không lấy Mực nữa, đổi thành Cháo Hàu đi",
          "assert": {
            "tool_called": "sync_cart",
            "tool_must_NOT_call": "confirm_order",
            "response_should_contain_one_of": ["Cháo Hàu", "Cháo"]
          }
        },
        {
          "turn": 3,
          "role": "user",
          "content": "Ok đặt thôi",
          "assert": {
            "tool_called": "confirm_order",
            "response_contains": "đơn hàng",
            "confirmed_items_must_contain": "Cháo Hàu",
            "confirmed_items_must_NOT_contain": "Mực"
          }
        }
      ]
    },
    {
      "id": "E2E-008",
      "name": "full_flow_order_pay_verify",
      "description": "Luồng đầy đủ: gọi món → xác nhận → tính tiền → xác nhận đã thanh toán. Kiểm tra cả 4 tool theo thứ tự.",
      "table_id": "T_eval_8",
      "difficulty": "hard",
      "expected_outcome": "payment_verified",
      "turns": [
        {
          "turn": 1,
          "role": "user",
          "content": "Cho mình 1 phần Tôm Càng Xanh Nướng Phô Mai và 2 chai Bia Sài Gòn",
          "assert": {
            "tool_called": "sync_cart",
            "tool_output_contains": "Đã cập nhật"
          }
        },
        {
          "turn": 2,
          "role": "user",
          "content": "Đúng rồi xác nhận luôn",
          "assert": {
            "tool_called": "confirm_order",
            "confirmed_items_must_contain": "Tôm"
          }
        },
        {
          "turn": 3,
          "role": "user",
          "content": "Cho mình xin mã QR thanh toán",
          "assert": {
            "tool_called": "request_payment",
            "response_should_contain_one_of": ["QR", "Tổng tiền", "thanh toán"]
          }
        },
        {
          "turn": 4,
          "role": "user",
          "content": "Mình chuyển khoản xong rồi nha",
          "assert": {
            "tool_called": "verify_payment",
            "response_should_contain_one_of": ["thành công", "Cảm ơn"]
          }
        }
      ]
    },
    {
      "id": "E2E-009",
      "name": "modify_quantity",
      "description": "Khách gọi món rồi đổi số lượng. Đơn cuối phải đúng số lượng mới.",
      "table_id": "T_eval_9",
      "difficulty": "medium",
      "expected_outcome": "order_placed",
      "turns": [
        {
          "turn": 1,
          "role": "user",
          "content": "Cho mình 2 con Hàu Nướng Phô Mai",
          "assert": {
            "tool_called": "sync_cart",
            "tool_output_contains": "Đã cập nhật"
          }
        },
        {
          "turn": 2,
          "role": "user",
          "content": "Mà thôi cho mình 5 con luôn đi",
          "assert": {
            "tool_called": "sync_cart",
            "tool_must_NOT_call": "confirm_order",
            "response_should_contain_one_of": ["Hàu", "5", "tạm tính"]
          }
        },
        {
          "turn": 3,
          "role": "user",
          "content": "Ừ chốt nha",
          "assert": {
            "tool_called": "confirm_order",
            "confirmed_items_must_contain": "Hàu"
          }
        }
      ]
    },
    {
      "id": "E2E-010",
      "name": "chitchat_then_order",
      "description": "Khách tán gẫu trước, sau đó mới gọi món. Turn chat KHÔNG được gọi tool tạo đơn.",
      "table_id": "T_eval_10",
      "difficulty": "medium",
      "expected_outcome": "order_placed",
      "turns": [
        {
          "turn": 1,
          "role": "user",
          "content": "Chào em, quán hôm nay đông ghê ha",
          "assert": {
            "tool_must_NOT_call": "sync_cart",
            "response_should_contain_one_of": ["dạ", "chào", "ạ", "quán"]
          }
        },
        {
          "turn": 2,
          "role": "user",
          "content": "Thôi cho anh 1 phần Lẩu Thái đi",
          "assert": {
            "tool_called": "sync_cart",
            "tool_output_contains": "Đã cập nhật",
            "response_should_contain_one_of": ["Lẩu Thái", "tạm tính", "xác nhận"]
          }
        },
        {
          "turn": 3,
          "role": "user",
          "content": "Xác nhận đi em",
          "assert": {
            "tool_called": "confirm_order",
            "confirmed_items_must_contain": "Lẩu Thái"
          }
        }
      ]
    },
    {
      "id": "E2E-011",
      "name": "remove_one_of_two",
      "description": "Khách gọi 2 món rồi bỏ 1 món. Đơn cuối chỉ còn món còn lại.",
      "table_id": "T_eval_11",
      "difficulty": "hard",
      "expected_outcome": "order_placed",
      "turns": [
        {
          "turn": 1,
          "role": "user",
          "content": "Cho mình 2 phần Ốc Hương Xốt Trứng Muối và 2 chai Bia Sài Gòn",
          "assert": {
            "tool_called": "sync_cart",
            "tool_output_contains": "Đã cập nhật"
          }
        },
        {
          "turn": 2,
          "role": "user",
          "content": "Bỏ bia đi, không lấy bia nữa",
          "assert": {
            "tool_called": "sync_cart",
            "tool_must_NOT_call": "confirm_order",
            "response_should_contain_one_of": ["Ốc Hương", "tạm tính", "bỏ"]
          }
        },
        {
          "turn": 3,
          "role": "user",
          "content": "Ok đặt nha",
          "assert": {
            "tool_called": "confirm_order",
            "confirmed_items_must_contain": "Ốc Hương",
            "confirmed_items_must_NOT_contain": "Bia"
          }
        }
      ]
    }
  ]
}
