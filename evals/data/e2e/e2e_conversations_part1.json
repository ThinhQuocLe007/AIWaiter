{
  "dataset": "e2e_conversations",
  "version": "3.0",
  "part": 1,
  "description": "E2E ngắn, happy-path qua toàn graph (router → worker → tools → response) cho menu quán ốc/hải sản 'Ốc Quậy'. Tên món khớp menu.json. Tool: sync_cart, confirm_order, search, request_payment, verify_payment.",
  "total_scenarios": 6,
  "scenarios": [
    {
      "id": "E2E-001",
      "name": "happy_path_single_item",
      "description": "Khách gọi 1 món rõ ràng, xác nhận, hoàn tất. Kiểm tra luồng sync_cart → confirm_order cơ bản.",
      "table_id": "T_eval_1",
      "difficulty": "easy",
      "expected_outcome": "order_placed",
      "turns": [
        {
          "turn": 1,
          "role": "user",
          "content": "Cho mình 2 phần Ốc Hương xốt trứng muối",
          "assert": {
            "tool_called": "add_cart",
            "tool_output_contains": "Đã thêm",
            "response_should_contain_one_of": [
              "Ốc Hương",
              "tạm tính",
              "xác nhận",
              "đặt"
            ]
          }
        },
        {
          "turn": 2,
          "role": "user",
          "content": "Đúng rồi, xác nhận đặt luôn",
          "assert": {
            "tool_called": "confirm_order",
            "response_contains": "đơn hàng",
            "confirmed_items_must_contain": "Ốc Hương"
          }
        }
      ]
    },
    {
      "id": "E2E-002",
      "name": "multi_item_order",
      "description": "Khách gọi nhiều món trong một câu, xác nhận. Kiểm tra sync_cart gom đúng nhiều món.",
      "table_id": "T_eval_2",
      "difficulty": "easy",
      "expected_outcome": "order_placed",
      "turns": [
        {
          "turn": 1,
          "role": "user",
          "content": "Cho 6 con Hàu Nướng Phô Mai và 3 chai Bia Tiger Bạc nha",
          "assert": {
            "tool_called": "add_cart",
            "tool_output_contains": "Đã thêm",
            "response_should_contain_one_of": [
              "Hàu Nướng",
              "Bia",
              "tạm tính",
              "xác nhận"
            ]
          }
        },
        {
          "turn": 2,
          "role": "user",
          "content": "Ok chốt đơn đi em",
          "assert": {
            "tool_called": "confirm_order",
            "response_contains": "đơn hàng",
            "confirmed_items_must_contain": "Hàu"
          }
        }
      ]
    },
    {
      "id": "E2E-003",
      "name": "search_then_order",
      "description": "Khách hỏi về món trước (search), rồi mới gọi. Kiểm tra chuyển từ search_worker sang order_worker.",
      "table_id": "T_eval_3",
      "difficulty": "medium",
      "expected_outcome": "order_placed",
      "turns": [
        {
          "turn": 1,
          "role": "user",
          "content": "Lẩu Thái ở quán cay không em?",
          "assert": {
            "tool_called": "search",
            "tool_must_NOT_call": "confirm_order",
            "response_should_contain_one_of": [
              "cay",
              "Lẩu Thái",
              "chua"
            ]
          }
        },
        {
          "turn": 2,
          "role": "user",
          "content": "Vậy cho mình 1 phần Lẩu Thái",
          "assert": {
            "tool_called": "add_cart",
            "tool_output_contains": "Đã thêm",
            "response_should_contain_one_of": [
              "Lẩu Thái",
              "tạm tính",
              "xác nhận"
            ]
          }
        },
        {
          "turn": 3,
          "role": "user",
          "content": "Ừ đặt nha",
          "assert": {
            "tool_called": "confirm_order",
            "confirmed_items_must_contain": "Lẩu Thái"
          }
        }
      ]
    },
    {
      "id": "E2E-004",
      "name": "order_then_request_payment",
      "description": "Gọi món, xác nhận, rồi yêu cầu tính tiền. Kiểm tra payment_worker gọi request_payment.",
      "table_id": "T_eval_4",
      "difficulty": "medium",
      "expected_outcome": "payment_requested",
      "turns": [
        {
          "turn": 1,
          "role": "user",
          "content": "Cho mình 1 tô Cháo Hàu",
          "assert": {
            "tool_called": "add_cart",
            "tool_output_contains": "Đã thêm"
          }
        },
        {
          "turn": 2,
          "role": "user",
          "content": "Xác nhận đặt luôn",
          "assert": {
            "tool_called": "confirm_order",
            "confirmed_items_must_contain": "Cháo Hàu"
          }
        },
        {
          "turn": 3,
          "role": "user",
          "content": "Cho mình tính tiền nha",
          "assert": {
            "tool_called": "request_payment",
            "response_should_contain_one_of": [
              "QR",
              "Tổng tiền",
              "thanh toán"
            ]
          }
        }
      ]
    },
    {
      "id": "E2E-005",
      "name": "search_only_no_order",
      "description": "Khách chỉ hỏi thông tin, không gọi món. Agent KHÔNG được tạo đơn (không gọi sync_cart/confirm_order).",
      "table_id": "T_eval_5",
      "difficulty": "medium",
      "expected_outcome": "info_provided",
      "turns": [
        {
          "turn": 1,
          "role": "user",
          "content": "Quán mình có những món lẩu nào vậy?",
          "assert": {
            "tool_called": "search",
            "tool_must_NOT_call": "sync_cart",
            "response_should_contain_one_of": [
              "Lẩu",
              "lẩu"
            ]
          }
        },
        {
          "turn": 2,
          "role": "user",
          "content": "Thế Ốc Hương giá bao nhiêu một phần?",
          "assert": {
            "tool_called": "search",
            "tool_must_NOT_call": "confirm_order",
            "response_should_contain_one_of": [
              "85",
              "Ốc Hương",
              "giá"
            ]
          }
        }
      ]
    },
    {
      "id": "E2E-006",
      "name": "add_item_then_confirm",
      "description": "Gọi 1 món, sau đó gọi thêm món nữa, rồi xác nhận. Đơn cuối phải gồm cả 2 món.",
      "table_id": "T_eval_6",
      "difficulty": "medium",
      "expected_outcome": "order_placed",
      "turns": [
        {
          "turn": 1,
          "role": "user",
          "content": "Cho mình 2 phần Ốc Hương",
          "assert": {
            "tool_called": "add_cart",
            "tool_output_contains": "Đã thêm"
          }
        },
        {
          "turn": 2,
          "role": "user",
          "content": "Thêm 1 dĩa Khoai Tây Lắc Phô Mai nữa",
          "assert": {
            "tool_called": "add_cart",
            "tool_must_NOT_call": "confirm_order",
            "response_should_contain_one_of": [
              "Khoai Tây",
              "Ốc Hương",
              "tạm tính"
            ]
          }
        },
        {
          "turn": 3,
          "role": "user",
          "content": "Ok đặt hết luôn nha",
          "assert": {
            "tool_called": "confirm_order",
            "confirmed_items_must_contain": "Khoai Tây"
          }
        }
      ]
    }
  ]
}