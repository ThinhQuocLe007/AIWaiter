# Hugging Face Access Token
HF_TOKEN=your_token_here

# System Configuration
DEVICE=cuda
# Device for the embedding model only. Leave empty to follow DEVICE.
# On Jetson set EMBEDDING_DEVICE=cpu to free iGPU/unified RAM for the Ollama LLM.
EMBEDDING_DEVICE=cuda


# THE system encoder — one shared model for retrieval AND intent routing. There is no
# second encoder at runtime: classifier_router_node encodes through encode_queries() and
# hands the vector to the MLP, so this single choice feeds both.
#
# It must stay 768-dim (bkai) as long as the shipped classifier checkpoint is the one
# trained in src/training_semantic_router — the MLP's first layer is 768+10 wide and a
# 1024-dim model like AITeamVN/Vietnamese_Embedding raises EmbeddingModelMismatch /
# a width error on the first utterance. Retrain before switching.
#
# Changing it also means rebuilding both artifacts:
#   python scripts/setup.py --embeddings-only     # vector index
#   python scripts/build_centroids.py             # semantic-router centroids
EMBEDDING_MODEL=bkai-foundation-models/vietnamese-bi-encoder

# Encoder for the OFFLINE classifier scripts only (train / evaluate / benchmark / compare),
# which call classify() without a precomputed vector. Keep it equal to EMBEDDING_MODEL so
# training-time and serving-time vectors are produced the same way.
CLASSIFIER_EMBEDDING_MODEL=bkai-foundation-models/vietnamese-bi-encoder

# Router SLM model (Ollama) — used by all workers / response
ROUTER_MODEL=qwen2.5:14b-instruct-q6_K  
WORKER_MODEL=qwen2.5:14b-instruct-q6_K  
RESPONSE_MODEL=qwen2.5:14b-instruct-q6_K

# LangSmith Tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__your_key_here
LANGCHAIN_PROJECT=AI_Waiter_Dev

# Where the orchestrator (backend :8000) finds the LLM agent service (:8100). Only used to
# forward the tablet's "cuộc trò chuyện mới" reset; override when the agent runs on another host.
ORCH_AGENT_URL=http://127.0.0.1:8100
