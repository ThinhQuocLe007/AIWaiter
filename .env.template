# Hugging Face Access Token
HF_TOKEN=your_token_here

# System Configuration
DEVICE=cuda
# Device for the embedding model only. Leave empty to follow DEVICE.
# On Jetson set EMBEDDING_DEVICE=cpu to free iGPU/unified RAM for the Ollama LLM.
EMBEDDING_DEVICE=

# Embedding model. Empty = default (AITeamVN/Vietnamese_Embedding, 2.2GB, best VN).
# Flip to A/B a lighter one, then rebuild: python scripts/setup.py --embeddings-only
# Supported (see EMBEDDING_PROFILES in embeddings.py):
#   AITeamVN/Vietnamese_Embedding                  # 1024-dim ~560M ~2.2GB  best VN, heavy
#   bkai-foundation-models/vietnamese-bi-encoder   #  768-dim ~135M ~0.5GB  PhoBERT, VN-specialized
#   dangvantuan/vietnamese-embedding               #  768-dim ~135M ~0.5GB  PhoBERT SBERT
#   keepitreal/vietnamese-sbert                    #  768-dim ~135M ~0.5GB  PhoBERT SBERT (sBERT-Vi)
#   intfloat/multilingual-e5-small                 #  384-dim ~118M ~0.47GB lightest/fastest
#   intfloat/multilingual-e5-base                  #  768-dim ~278M ~1.1GB

EMBEDDING_MODEL=

# Router SLM model (Ollama) — used by slm_router_node
ROUTER_MODEL=gemma4:e2b-it-qat
WORKER_MODEL=gemma4:e2b-it-qat
RESPONSE_MODEL=gemma4:e2b-it-qat

# LangSmith Tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__your_key_here
LANGCHAIN_PROJECT=AI_Waiter_Dev
