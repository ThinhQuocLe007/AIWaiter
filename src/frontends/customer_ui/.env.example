# Customer UI (touchscreen) environment variables
# All variables must be prefixed with VITE_ to be exposed to the browser

# Backend API — đường dẫn tương đối, đi qua Vite proxy sang FastAPI:8000 (vite.config.ts).
# Cùng origin nên KHÔNG dính CORS. Chỉ đặt URL tuyệt đối nếu backend ở máy/khác origin.
VITE_API_URL=/api

# WebSocket URL for streaming (LLM responses, voice, robot status) — qua Vite proxy.
VITE_WS_URL=/ws

# ROS2 rosbridge WebSocket URL (robot navigation / hardware bridge)
VITE_ROS_BRIDGE_URL=ws://localhost:9090

# App display name
VITE_APP_NAME=AI Waiter

# Feature flags
VITE_ENABLE_VOICE=true
VITE_ENABLE_DEBUG_PANEL=false
